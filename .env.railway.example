# Railway deployment example.
# Add backend variables to the backend service and frontend variables to the frontend service.
# Keep real values only in Railway, not in Git.

### Backend service
DJANGO_ENV=production
DJANGO_PRODUCTION=true
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=<generate-a-long-random-secret>
DJANGO_ENABLE_ADMIN=false
DJANGO_DB_ENGINE=postgres
DATABASE_URL=<railway-postgres-database-url>
DJANGO_CACHE_BACKEND=locmem

# Railway normally provides this automatically after you create a public domain.
RAILWAY_PUBLIC_DOMAIN=<backend-service>.up.railway.app

# Optional explicit allowlist. If omitted, the app derives it from RAILWAY_PUBLIC_DOMAIN.
DJANGO_ALLOWED_HOSTS=<backend-service>.up.railway.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://<backend-service>.up.railway.app,https://<frontend-service>.up.railway.app

DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false

JWT_ACCESS_MINUTES=20
JWT_REFRESH_DAYS=7

### Frontend service
NEXT_OUTPUT_MODE=standalone
NEXT_PUBLIC_API_PROXY=1
NEXT_API_PROXY_TARGET=https://<backend-service>.up.railway.app
BACKEND_INTERNAL_URL=https://<backend-service>.up.railway.app
NEXT_PUBLIC_API_BASE_URL=/api

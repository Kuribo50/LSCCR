# Local development example. Copy to .env and change local-only values.
# Do not commit .env.

# Django
DJANGO_ENV=development
DJANGO_PRODUCTION=false
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
DJANGO_ENABLE_ADMIN=true
DJANGO_DB_ENGINE=sqlite
DJANGO_CACHE_BACKEND=locmem

# Optional local PostgreSQL for docker-compose
POSTGRES_DB=lista_espera_ccr
POSTGRES_USER=lista_espera_ccr
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional local Redis for docker-compose
REDIS_HOST=redis
REDIS_PORT=6379

# JWT and API limits
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=300/minute
DRF_THROTTLE_AUTH_LOGIN=10/minute
DRF_THROTTLE_AUTH_REFRESH=20/minute

# Frontend
NEXT_PUBLIC_API_PROXY=1
NEXT_API_PROXY_TARGET=http://localhost:8000
BACKEND_INTERNAL_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=/api

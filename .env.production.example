# Production example. Copy values into your hosting provider variables.
# Never commit real secrets.

# Django backend
DJANGO_ENV=production
DJANGO_PRODUCTION=true
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=<generate-a-long-random-secret>
DJANGO_ENABLE_ADMIN=false

# Set these to your deployed backend/frontend domains.
DJANGO_ALLOWED_HOSTS=<backend-domain>
DJANGO_CSRF_TRUSTED_ORIGINS=https://<backend-domain>,https://<frontend-domain>

# Database
DJANGO_DB_ENGINE=postgres
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>

# Cache. Use locmem if no Redis service is available.
DJANGO_CACHE_BACKEND=locmem
REDIS_HOST=<redis-host>
REDIS_PORT=6379

# HTTPS hardening
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false

# JWT and API limits
JWT_ACCESS_MINUTES=20
JWT_REFRESH_DAYS=7
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=300/minute
DRF_THROTTLE_AUTH_LOGIN=10/minute
DRF_THROTTLE_AUTH_REFRESH=20/minute

# Next.js frontend
NEXT_OUTPUT_MODE=standalone
NEXT_PUBLIC_API_PROXY=1
NEXT_API_PROXY_TARGET=https://<backend-domain>
BACKEND_INTERNAL_URL=https://<backend-domain>
NEXT_PUBLIC_API_BASE_URL=/api
